# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading_secret
POSTGRES_DB=trading_ai
DATABASE_URL=postgresql+asyncpg://trading:trading_secret@postgres:5432/trading_ai

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security (REQUIRED — generate before first run) ─────────
# JWT secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# Fernet key for encrypting per-user broker API keys at rest:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_generate_with_Fernet_generate_key

# Admin account password (set before first run; cannot be blank)
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Never use *.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── OANDA (Forex, XAU, XAG) ─────────────────────────────────
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_ENVIRONMENT=practice

# ─── Alpaca (US Stocks) ───────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Crypto (Coinbase / Binance) ─────────────────────────────
# Data feeds only for now; execution keys are per-user (BYO model, stored encrypted).
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ─── PayPal (subscription billing only — platform never holds user funds) ─────
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_secret
PAYPAL_MODE=sandbox

# ─── App ──────────────────────────────────────────────────────
TRADING_MODE=PAPER
INITIAL_VIRTUAL_BALANCE=10000.00
MAX_DRAWDOWN_LIMIT=0.10
RISK_PER_TRADE=0.01
FINAL_SCORE_THRESHOLD=0.85
CONFIDENCE_THRESHOLD=0.70

# ─── Frontend (Vite) ──────────────────────────────────────────
# Dev (Vite dev server on :5173, backend on :8000) — fill these in:
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
# Production with nginx reverse proxy — leave BOTH EMPTY in docker-compose.prod.yml
# (nginx proxies /api/ and /ws/ to the backend container; WS host is derived from window.location).
# Only set these if the backend is on a different host or port than the nginx frontend.
